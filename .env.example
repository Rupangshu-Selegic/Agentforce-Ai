# Copy this file to .env and fill in your real values

# Your Salesforce org domain (no trailing slash)
# Example: https://yourcompany.my.salesforce.com
SF_ORG_DOMAIN=https://your-org.my.salesforce.com

# From your External Client App (Connected App)
SF_CLIENT_ID=your_client_id_here
SF_CLIENT_SECRET=your_client_secret_here

# Model to use — options:
#   sfdc_ai__DefaultGPT35Turbo              (fastest, cheapest)
#   sfdc_ai__DefaultOpenAIGPT4OmniMini      (balanced)
#   sfdc_ai__DefaultOpenAIGPT4Omni          (best quality)
#   sfdc_ai__DefaultBedrockAnthropicClaude3Sonnet
SF_MODEL=sfdc_ai__DefaultGPT35Turbo
